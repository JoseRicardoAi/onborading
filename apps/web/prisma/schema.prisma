generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OnboardingStatus {
  cadastro_iniciado
  pendente_informacoes
  cadastro_completo
  revisado
}

model Employee {
  id                   String                 @id @default(uuid()) @db.Uuid
  fullName             String                 @map("full_name")
  birthDate            DateTime?              @map("birth_date") @db.Date
  phone                String?
  email                String?
  instagram            String?
  residentialAddress   String?                @map("residential_address")
  uniformShirtSize     String?                @map("uniform_shirt_size")
  uniformPantsSize     String?                @map("uniform_pants_size")
  uniformShoeSize      String?                @map("uniform_shoe_size")
  status               OnboardingStatus       @default(cadastro_iniciado)
  completionPercent    Int                    @default(0) @map("completion_percent")
  submittedAt          DateTime?              @map("submitted_at") @db.Timestamptz(6)
  reviewedAt           DateTime?              @map("reviewed_at") @db.Timestamptz(6)
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?              @map("deleted_at") @db.Timestamptz(6)
  children             Child[]
  educationProfile     EducationProfile?
  emergencyContact     EmergencyContact?
  healthProfile        HealthProfile?
  spouse               Spouse?
  onboardingAccessTokens OnboardingAccessToken[]

  @@index([status], map: "idx_employees_status")
  @@index([fullName], map: "idx_employees_full_name")
  @@index([deletedAt], map: "idx_employees_deleted_at")
  @@map("employees")
}

model Child {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  name       String
  gender     String?
  birthDate  DateTime @map("birth_date") @db.Date
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "idx_children_employee")
  @@map("children")
}

model Spouse {
  id                  String   @id @default(uuid()) @db.Uuid
  employeeId          String   @unique @map("employee_id") @db.Uuid
  name                String
  phone               String?
  weddingAnniversary  DateTime? @map("wedding_anniversary") @db.Date
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("spouses")
}

model HealthProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  employeeId           String    @unique @map("employee_id") @db.Uuid
  continuousMedication String?   @map("continuous_medication")
  allergies            String?
  relevantCondition    String?   @map("relevant_condition")
  workRestriction      String?   @map("work_restriction")
  additionalNotes      String?   @map("additional_notes")
  consentAcceptedAt    DateTime? @map("consent_accepted_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("health_profiles")
}

model EmergencyContact {
  id        String   @id @default(uuid()) @db.Uuid
  employeeId String  @unique @map("employee_id") @db.Uuid
  name      String
  phone     String
  address   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

model EducationProfile {
  id             String    @id @default(uuid()) @db.Uuid
  employeeId     String    @unique @map("employee_id") @db.Uuid
  institution    String?
  courseName     String?   @map("course_name")
  courseSchedule String?   @map("course_schedule")
  expectedEndDate DateTime? @map("expected_end_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("education_profiles")
}

model OnboardingAccessToken {
  id               String    @id @default(uuid()) @db.Uuid
  employeeId       String    @map("employee_id") @db.Uuid
  tokenHash        String    @unique @map("token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt           DateTime? @map("used_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdByAdminId String?   @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdByAdmin   AdminUser? @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([employeeId], map: "idx_onboarding_access_tokens_employee")
  @@map("onboarding_access_tokens")
}

model AdminUser {
  id          String                 @id @default(uuid()) @db.Uuid
  email       String                 @unique
  fullName    String?                @map("full_name")
  isActive    Boolean                @default(true) @map("is_active")
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tokensCreated OnboardingAccessToken[]

  @@map("admin_users")
}
